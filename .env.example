# Ambiente da aplicacao
# dev = desenvolvimento local
# prod = configuracao endurecida para producao
APP_ENV=dev

# Django
DEBUG=True
SECRET_KEY=substitua-por-uma-chave-secreta-longa-e-aleatoria
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=

# Banco de dados
# Para usar PostgreSQL, preencha os campos abaixo.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Se DB_NAME estiver vazio, o projeto usa SQLite automaticamente.
