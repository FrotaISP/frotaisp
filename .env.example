# Ambiente da aplicacao
# dev = desenvolvimento local
# prod = configuracao endurecida para producao
# test = configuracao dedicada para testes automatizados
APP_ENV=dev

# Django
DEBUG=True
SECRET_KEY=substitua-por-uma-chave-secreta-longa-e-aleatoria
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=

# Banco de dados
# Se DB_NAME estiver vazio em APP_ENV=dev, o projeto usa SQLite automaticamente.
# Em APP_ENV=prod, todos os campos DB_* abaixo devem estar preenchidos.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
CONN_MAX_AGE=60
